# GitHub personal access token (optional but recommended)
# Without it: 60 API requests/hr. With it: 5000/hr.
# Create at: https://github.com/settings/tokens → "Generate new token (classic)"
# Scopes needed: public_repo (for public repos) or repo (for private repos)
GITHUB_TOKEN=

# Custom data directory (default: ./data)
# REPOINDEX_DATA_DIR=
